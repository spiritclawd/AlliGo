# Allimolt Environment Configuration
# Copy this file to .env and fill in your values

# Brave Search API Key for data ingestion
# Get yours at: https://brave.com/search/api/
BRAVE_API_KEY=your_brave_api_key_here

# Server Configuration
PORT=3399
NODE_ENV=development

# Database (for future PostgreSQL migration)
# DATABASE_URL=postgresql://user:password@localhost:5432/allimolt

# Security
# JWT_SECRET=your-secret-key-here
# API_KEY_REQUIRED=false
